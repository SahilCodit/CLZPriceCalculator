# Environment Variables for Azure Static Web Apps Deployment Pipeline
#
# HOW TO USE:
# 1. Copy this file to .env and fill in your values (for local reference only).
# 2. The values below that reference GitHub Secrets MUST be configured in your
#    GitHub repository under Settings > Secrets and variables > Actions.
#
# For full setup instructions, see:
# https://learn.microsoft.com/azure/static-web-apps/get-started-portal?tabs=vanilla-javascript

# ---------------------------------------------------------------------------
# REQUIRED — GitHub Repository Secret
# ---------------------------------------------------------------------------
# The deployment API token for your Azure Static Web App.
# To obtain this token:
#   1. Open your Static Web App resource in the Azure portal.
#   2. Go to Settings > Deployment tokens.
#   3. Copy the token value.
# Then add it as a GitHub Secret named exactly:  AZURE_STATIC_WEB_APPS_API_TOKEN
#
# In your GitHub repository: Settings > Secrets and variables > Actions > New repository secret
AZURE_STATIC_WEB_APPS_API_TOKEN=ba814943cc96be9ad3f623273afdd7ea4484fca23e28fe5147a83d52679bbe5e06-44e2f9ce-78ae-4260-b182-85e45bfcd0f6003003201b7cfe03

# ---------------------------------------------------------------------------
# OPTIONAL — Workflow-level environment variables (set in the workflow YAML)
# ---------------------------------------------------------------------------
# These are already configured in .github/workflows/azure-staticwebapp.yml.
# Update them there if your project layout changes.

# Path to your front-end source code (relative to the repository root).
# Default: "/"  — repository root (used for this vanilla HTML project)
APP_LOCATION=/

# Path to your Azure Functions API source code (leave empty if no API).
# Default: "api"
API_LOCATION=api

# Path where your build output is placed.
# Default: "build"  (set to "" or "." if no build step is needed)
APP_ARTIFACT_LOCATION=build
